{
    "name": "ez-ecommerce/ez-ecommerce",
    "description": "A modular, headless e-commerce engine for Laravel.",
    "keywords": [
        "ez-ecommerce",
        "laravel",
        "ecommerce",
        "commerce",
        "headless"
    ],
    "homepage": "https://github.com/ez-ecommerce/ez-ecommerce",
    "license": "MIT",
    "authors": [
        {
            "name": "ez-ecommerce",
            "email": "hello@ez-ecommerce.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "brick/money": "^0.10",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/uid": "^6.4|^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EzEcommerce\\": "src/",
            "EzEcommerce\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EzEcommerce\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EzEcommerce\\EzEcommerceServiceProvider"
            ],
            "aliases": {
                "EzEcommerce": "EzEcommerce\\Facades\\EzEcommerce"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "suggest": {
        "stripe/stripe-php": "For Stripe payment driver",
        "paypal/paypal-checkout-sdk": "For PayPal payment driver"
    }
}
